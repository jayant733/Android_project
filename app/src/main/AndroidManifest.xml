<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ✅ REQUIRED FOR FIREBASE -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TripSync">

        <!-- ✅ Service -->
        <service
            android:name=".service.TripReminderService"
            android:exported="false" />

        <!-- ✅ Broadcast Receiver -->
        <receiver
            android:name=".reciever.BatteryLowReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BATTERY_LOW" />
            </intent-filter>
        </receiver>

        <!-- 🔐 LOGIN (NOW LAUNCHER) -->
        <activity
            android:name=".ui.activities.LoginActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- 🔐 SIGNUP -->
        <activity
            android:name=".ui.activities.SignUpActivity"
            android:exported="false" />

        <!-- ✅ MAIN APP SCREEN -->
        <activity
            android:name=".ui.activities.TripListActivity"
            android:exported="false" />

        <!-- ✅ Other screens -->
        <activity
            android:name=".ui.activities.TripDetailsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.activities.CreateTripActivity"
            android:exported="false" />

        <activity
            android:name=".ui.activities.ProfileActivity"
            android:exported="false" />

        <activity
            android:name=".ui.activities.CollaboratorsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.activities.PastTripsActivity"
            android:exported="false" />

        <!-- ✅ Content Provider -->
        <provider
            android:name=".data.provider.TripContentProvider"
            android:authorities="com.example.tripsync.provider"
            android:exported="true" />

    </application>

</manifest>
