<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9FAFB"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Past Trips"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#111827" />

    <TextView
        android:id="@+id/tvPastTripCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Completed Trips: 0"
        android:textColor="#6B7280"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp" />

    <ListView
        android:id="@+id/listPastTrips"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:dividerHeight="6dp"
        android:background="#FFFFFF" />

    <Button
        android:id="@+id/btnBackPastTrips"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Back"
        android:background="@drawable/bg_outline_button"
        android:textColor="#6366F1"
        android:textAllCaps="false"
        android:layout_marginTop="12dp" />
</LinearLayout>
