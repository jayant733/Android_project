<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:clipToPadding="false"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_accent_panel"
            android:elevation="7dp"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_teal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Trip Group"
                android:textColor="@color/brand_secondary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvGroupTripTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Trip Name"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Invite members, track contributions, and settle the group cleanly."
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etGroupName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_input_surface"
                android:hint="Group Name"
                android:paddingHorizontal="18dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary" />

            <Button
                android:id="@+id/btnSaveGroupName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_outline_button"
                android:text="Save Group Name"
                android:textAllCaps="false"
                android:textColor="@color/brand_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Invite Members"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvInviteHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Invites are delivered inside the app."
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etMemberName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input_surface"
                android:hint="Member Name"
                android:paddingHorizontal="18dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary" />

            <EditText
                android:id="@+id/etMemberEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_surface"
                android:hint="Member Email"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="18dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary" />

            <Button
                android:id="@+id/btnAddMember"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_primary_button"
                android:text="Send Invite"
                android:textAllCaps="false"
                android:textColor="@color/text_on_brand"
                android:textStyle="bold" />

            <ListView
                android:id="@+id/listMembers"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp"
                android:background="@android:color/transparent"
                android:divider="@android:color/transparent"
                android:dividerHeight="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Split Bills"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerPaidBy"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input_surface"
                android:paddingHorizontal="10dp" />

            <EditText
                android:id="@+id/etExpenseAmount"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_surface"
                android:hint="Expense Amount"
                android:inputType="numberDecimal"
                android:paddingHorizontal="18dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary" />

            <EditText
                android:id="@+id/etExpenseDesc"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_surface"
                android:hint="Expense Description"
                android:paddingHorizontal="18dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary" />

            <Button
                android:id="@+id/btnAddExpense"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_primary_button"
                android:text="Add Split Bill"
                android:textAllCaps="false"
                android:textColor="@color/text_on_brand"
                android:textStyle="bold" />

            <ListView
                android:id="@+id/listExpenses"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp"
                android:background="@android:color/transparent"
                android:divider="@android:color/transparent"
                android:dividerHeight="8dp" />

            <Button
                android:id="@+id/btnCalculateSettlement"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_secondary_button"
                android:text="Calculate Settlement"
                android:textAllCaps="false"
                android:textColor="@color/text_on_brand"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnBackMembers"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_outline_button"
            android:text="Back"
            android:textAllCaps="false"
            android:textColor="@color/brand_primary" />
    </LinearLayout>
</ScrollView>
