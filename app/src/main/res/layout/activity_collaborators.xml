<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trip Group"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <TextView
                android:id="@+id/tvGroupTripTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trip Name"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:layout_marginTop="4dp" />

            <EditText
                android:id="@+id/etGroupName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Group Name"
                android:layout_marginTop="14dp"
                android:padding="14dp" />

            <Button
                android:id="@+id/btnSaveGroupName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Save Group Name"
                android:background="@drawable/bg_outline_button"
                android:textColor="#6366F1"
                android:textAllCaps="false"
                android:layout_marginTop="10dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Invite Members"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <TextView
                android:id="@+id/tvInviteHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Invites are delivered inside the app."
                android:textColor="#6B7280"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etMemberName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Member Name"
                android:padding="14dp" />

            <EditText
                android:id="@+id/etMemberEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Member Email"
                android:inputType="textEmailAddress"
                android:padding="14dp"
                android:layout_marginTop="10dp" />

            <Button
                android:id="@+id/btnAddMember"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Send Invite"
                android:background="@drawable/bg_primary_button"
                android:textColor="@android:color/white"
                android:textAllCaps="false"
                android:layout_marginTop="12dp" />

            <ListView
                android:id="@+id/listMembers"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp"
                android:dividerHeight="6dp"
                android:background="#FFFFFF" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Split Bills"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <Spinner
                android:id="@+id/spinnerPaidBy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/etExpenseAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Expense Amount"
                android:inputType="numberDecimal"
                android:padding="14dp"
                android:layout_marginTop="10dp" />

            <EditText
                android:id="@+id/etExpenseDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Expense Description"
                android:padding="14dp"
                android:layout_marginTop="10dp" />

            <Button
                android:id="@+id/btnAddExpense"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Add Split Bill"
                android:background="@drawable/bg_primary_button"
                android:textColor="@android:color/white"
                android:textAllCaps="false"
                android:layout_marginTop="12dp" />

            <ListView
                android:id="@+id/listExpenses"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp"
                android:dividerHeight="6dp"
                android:background="#FFFFFF" />

            <Button
                android:id="@+id/btnCalculateSettlement"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Calculate Settlement"
                android:background="@drawable/bg_outline_button"
                android:textColor="#6366F1"
                android:textAllCaps="false"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnBackMembers"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Back"
            android:background="@drawable/bg_outline_button"
            android:textColor="#6366F1"
            android:textAllCaps="false" />

    </LinearLayout>
</ScrollView>
