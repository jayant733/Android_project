<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:padding="0dp">

    <ImageView
        android:id="@+id/ivTripItemCover"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:background="@drawable/bg_image_placeholder"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:background="#260F172A" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/ivTripItemCover"
        android:layout_toStartOf="@id/ivMenu"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTripItemName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="18dp"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTripItemDestination"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:textColor="#ECF3FF"
            android:textSize="13sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/ivMenu"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/bg_chip_soft"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_more"
        android:tint="@color/brand_primary" />

</RelativeLayout>
