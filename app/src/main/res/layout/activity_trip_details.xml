<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:clipToPadding="false"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:elevation="7dp"
            android:orientation="vertical"
            android:padding="18dp">

            <ImageView
                android:id="@+id/ivTripImage"
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:background="@drawable/bg_image_placeholder"
                android:scaleType="centerCrop" />

            <Button
                android:id="@+id/btnUpdateTripImage"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_outline_button"
                android:text="Update Trip Cover"
                android:textAllCaps="false"
                android:textColor="@color/brand_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTripName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDestination"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvStartDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_tertiary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_status_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:textColor="@color/text_on_brand"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Trip Notes"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPlan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Spending Overview"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Spent"
                android:textColor="@color/text_tertiary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvTotalSpent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="₹0.00"
                android:textColor="@color/text_primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvExpenseEntries"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="0 entries"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvMemberCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="0 travelers"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnStartTrip"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="7dp"
                android:layout_weight="1"
                android:background="@drawable/bg_primary_button"
                android:text="Start"
                android:textAllCaps="false"
                android:textColor="@color/text_on_brand"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnCompleteTrip"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="7dp"
                android:layout_weight="1"
                android:background="@drawable/bg_warm_button"
                android:text="Complete"
                android:textAllCaps="false"
                android:textColor="@color/text_on_brand"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnCollaborators"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="7dp"
                android:layout_weight="1"
                android:background="@drawable/bg_secondary_button"
                android:text="Trip Group"
                android:textAllCaps="false"
                android:textColor="@color/text_on_brand"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnMyGroups"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="7dp"
                android:layout_weight="1"
                android:background="@drawable/bg_outline_button"
                android:text="My Groups"
                android:textAllCaps="false"
                android:textColor="@color/brand_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnDeleteTrip"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_danger_button"
            android:text="Delete Trip"
            android:textAllCaps="false"
            android:textColor="@color/text_on_brand"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_outline_button"
            android:text="Back"
            android:textAllCaps="false"
            android:textColor="@color/brand_primary" />
    </LinearLayout>
</ScrollView>
