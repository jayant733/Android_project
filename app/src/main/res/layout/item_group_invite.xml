<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvInviteGroupName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Goa Crew"
        android:textColor="@color/text_primary"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvInviteTripName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="Goa Trip"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/tvInviteFrom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_chip_teal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:text="From: friend@email.com"
        android:textColor="@color/brand_secondary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnAcceptInvite"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_secondary_button"
            android:text="Accept"
            android:textAllCaps="false"
            android:textColor="@color/text_on_brand"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnRejectInvite"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_outline_button"
            android:text="Decline"
            android:textAllCaps="false"
            android:textColor="@color/brand_primary"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
