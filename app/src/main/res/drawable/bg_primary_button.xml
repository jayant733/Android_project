<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/brand_secondary_dark" />
            <corners android:radius="14dp" />
            <stroke
                android:width="1dp"
                android:color="#24FFFFFF" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:angle="315"
                android:startColor="#58E1D1"
                android:endColor="@color/brand_secondary_dark" />
            <corners android:radius="14dp"/>
            <stroke
                android:width="1dp"
                android:color="#24FFFFFF" />
        </shape>
    </item>
</selector>
