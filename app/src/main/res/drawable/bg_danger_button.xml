<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/danger" />
            <corners android:radius="14dp"/>
            <stroke
                android:width="1dp"
                android:color="#1EFFFFFF" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:angle="315"
                android:startColor="#F98888"
                android:endColor="@color/danger" />
            <corners android:radius="14dp"/>
            <stroke
                android:width="1dp"
                android:color="#1EFFFFFF" />
        </shape>
    </item>
</selector>
