<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/brand_secondary_dark" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="#14FFFFFF" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:angle="315"
                android:startColor="@color/brand_secondary"
                android:endColor="@color/brand_secondary_dark" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="#14FFFFFF" />
        </shape>
    </item>
</selector>
